# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Optional dedicated pepper for OTP HMAC (falls back to NEXTAUTH_SECRET)
# AUTH_CODE_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Postgres — local Docker default; replace with hosted URL on deploy
DATABASE_URL=postgresql://docs:docs@localhost:5432/google_docs_clone

# SMTP — required for email verification and password reset codes
SMTP_HOST=
SMTP_PORT=587
# Set to true for port 465 (implicit TLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Google Docs Clone <noreply@example.com>"

# Google Gemini (AI Studio) — https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: override the Gemini model (default: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash
# One request per user per AI action within this window (default: 5)
AI_RATE_LIMIT_MINUTES=50
